# Copy to apps/api/.env, apps/web/.env.local, packages/db/.env as appropriate.
# Ports here are picked to avoid clashes with other Docker projects on this host;
# adjust freely if you do not have those running.

# ---------- Database ----------
DATABASE_URL=postgresql://ayurconnect:dev@localhost:5435/ayurconnect

# ---------- API server ----------
PORT=4100
HOST=0.0.0.0
SOCKET_PORT=4101
NODE_ENV=development

# ---------- Better Auth ----------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-bytes-base64
BETTER_AUTH_URL=http://localhost:4100

# ---------- Redis ----------
REDIS_URL=redis://localhost:6381

# ---------- Meilisearch ----------
MEILI_HOST=http://localhost:7701
MEILI_KEY=ayurconnect-dev-master-key

# ---------- MinIO (S3-compatible) ----------
S3_ENDPOINT=localhost
S3_PORT=9002
S3_USE_SSL=false
S3_ACCESS_KEY=ayurconnect
S3_SECRET_KEY=ayurconnect-dev-secret

# ---------- AI / AyurBot LLM provider ----------
# AyurBot auto-picks the first available, in this order: Gemini > Groq > Anthropic.
# You only need ONE of these for AyurBot to work. Override with AYURBOT_PROVIDER.

# Gemini 2.5 Flash — FREE tier (15 req/min, 1M tokens/day). Recommended.
# Get key at: https://aistudio.google.com/apikey  (starts with AIza, ~39 chars)
GOOGLE_API_KEY=

# Groq Llama 3.3 70B — FREE tier (30 req/min). Very fast.
# Get key at: https://console.groq.com/keys  (starts with gsk_, ~56 chars)
GROQ_API_KEY=

# Anthropic Claude Haiku 4.5 — paid (~$0.001/reply).
# Get key at: https://console.anthropic.com/settings/keys  (starts with sk-ant-)
ANTHROPIC_API_KEY=

# Optional: force a specific provider (gemini|groq|anthropic). Otherwise auto.
# AYURBOT_PROVIDER=gemini

VOYAGE_API_KEY=pa-replace-me

# ---------- Resend (transactional email) ----------
# Sign up at https://resend.com (free tier: 3000 emails/mo, 100/day)
# Once set, Better Auth will require email verification on signup + send via Resend.
# RESEND_FROM must be from a domain you've verified in Resend's dashboard.
RESEND_API_KEY=
RESEND_FROM=AyurConnect <hello@ayurconnect.com>

# ---------- Razorpay (payments) ----------
# Sign up at https://dashboard.razorpay.com → Settings → API Keys
# Use test mode keys for now (rzp_test_...). Switch to live when ready.
# Once set, /book/<doctor>/pay button activates Razorpay Checkout.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret — set after registering https://ayurconnect.com/api/payments/webhook
# in Razorpay Dashboard → Webhooks. Razorpay HMAC-SHA256-signs each delivery with this.
RAZORPAY_WEBHOOK_SECRET=

# ---------- Twilio (transactional SMS + WhatsApp — optional) ----------
# https://console.twilio.com → Account info. Without these, sendSms() / sendWhatsApp() are no-ops.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                # SMS sender phone number, e.g. +12345678900
# WhatsApp Business sender. Get a sandbox at:
# https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
# Format: whatsapp:+14155238886 (full prefixed) — or omit to fall back to TWILIO_FROM.
TWILIO_WHATSAPP_FROM=

# ---------- PostHog (product analytics — optional) ----------
# https://app.posthog.com/settings/project. Public key, safe to ship to browser.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---------- Google Maps (optional, link-out works without key) ----------
# Only needed if you want embed iframes. Link-out (Directions, Search) works without.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ---------- Daily.co video consultation (optional) ----------
# Get key at https://dashboard.daily.co/developers (free plan: 10000 min/mo).
# DAILY_DOMAIN is the subdomain prefix you chose (rooms become https://{DOMAIN}.daily.co/{room}).
DAILY_API_KEY=
DAILY_DOMAIN=

# ---------- Gemini embedding model (optional override) ----------
# Default: text-embedding-004 (768-dim, free). Try gemini-embedding-001 for newer.
GEMINI_EMBEDDING_MODEL=

# ---------- Web app (NEXT_PUBLIC_*) ----------
NEXT_PUBLIC_API_URL=http://localhost:4100
NEXT_PUBLIC_SOCKET_URL=http://localhost:4101
NEXT_PUBLIC_APP_URL=http://localhost:3100
