# Copy to apps/api/.env, apps/web/.env.local, packages/db/.env as appropriate.
# Ports here are picked to avoid clashes with other Docker projects on this host;
# adjust freely if you do not have those running.

# ---------- Database ----------
DATABASE_URL=postgresql://ayurconnect:dev@localhost:5435/ayurconnect

# ---------- API server ----------
PORT=4100
HOST=0.0.0.0
SOCKET_PORT=4101
NODE_ENV=development

# ---------- Better Auth ----------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-bytes-base64
BETTER_AUTH_URL=http://localhost:4100

# ---------- Redis ----------
REDIS_URL=redis://localhost:6381

# ---------- Meilisearch ----------
MEILI_HOST=http://localhost:7701
MEILI_KEY=ayurconnect-dev-master-key

# ---------- MinIO (S3-compatible) ----------
S3_ENDPOINT=localhost
S3_PORT=9002
S3_USE_SSL=false
S3_ACCESS_KEY=ayurconnect
S3_SECRET_KEY=ayurconnect-dev-secret

# ---------- AI ----------
ANTHROPIC_API_KEY=sk-ant-replace-me
VOYAGE_API_KEY=pa-replace-me

# ---------- Web app (NEXT_PUBLIC_*) ----------
NEXT_PUBLIC_API_URL=http://localhost:4100
NEXT_PUBLIC_SOCKET_URL=http://localhost:4101
NEXT_PUBLIC_APP_URL=http://localhost:3100
