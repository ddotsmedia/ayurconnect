generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ---------- Better Auth (https://www.better-auth.com) ----------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("USER") // USER | DOCTOR_PENDING | DOCTOR | HOSPITAL_PENDING | HOSPITAL | THERAPIST | ADMIN
  doctorId      String?   @unique // optional 1:1 link to Doctor row this user manages
  hospitalId    String?   @unique // optional 1:1 link to Hospital row this user manages
  prakriti      String?   // vata | pitta | kapha | (combinations like 'pitta-vata')
  phone         String?   // E.164: +91XXXXXXXXXX
  country       String?   // ISO 3166-1 alpha-2 (IN, US, AE, GB...). null = unknown / pre-internationalisation row.
  state         String?   // first-level admin division (Kerala, California, Dubai, England...)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  reviews       Review[]
  posts         Post[]
  comments      Comment[]
  jobs          Job[]
  appointments  Appointment[]
  upvotes       Upvote[]
  savedDoctors  SavedDoctor[]
  ownedDoctor   Doctor?       @relation("OwnedDoctor",   fields: [doctorId],   references: [id])
  ownedHospital Hospital?     @relation("OwnedHospital", fields: [hospitalId], references: [id])
  notifications Notification[]
  journal       JournalEntry[]
  assignedLeads Lead[]        @relation("LeadAssignee")
}

// ─── Patient health journal (added 2026-05-10) ────────────────────────────
// Daily wellness log. Used to track symptoms over time and feed the AI
// weekly summary endpoint that reports trends in dosha imbalance.
model JournalEntry {
  id           String   @id @default(cuid())
  userId       String
  // Date (without time component) — one entry per user per day.
  date         DateTime @db.Date
  mood         Int?     // 1-5
  sleepHours   Float?
  energy       Int?     // 1-5
  symptoms     String[] @default([])
  doshaFeel    String?  // vata | pitta | kapha | balanced
  food         String?  // free-text food log
  notes        String?  // anything else
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Notifications (added 2026-05-10 — Socket.io real-time delivery) ──────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  // Stable type so the UI can pick an icon/colour:
  //   appointment-booked | appointment-confirmed | appointment-cancelled |
  //   review-received    | doctor-verified       | hospital-verified     |
  //   forum-reply        | system
  type      String
  title     String
  body      String?
  link      String?  // optional URL to navigate to when clicked
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ---------- Domain models ----------

model Doctor {
  id                 String   @id @default(cuid())
  name               String
  specialization     String
  // Geography (added 2026-05-11). country defaults to 'IN' so existing Kerala
  // rows remain valid. `state` is the first-level admin division (Kerala for
  // legacy rows; backfilled in migration). `district` is kept for back-compat
  // and now means city/region within state.
  country            String   @default("IN")
  state              String?
  district           String   // legacy: was Kerala-only; now a generic city/region within state
  ccimVerified       Boolean  @default(false)
  profile            String?  // short tagline / one-liner
  bio                String?  // long-form biography
  qualification      String?  // "BAMS, MD (Ayurveda)"
  experienceYears    Int?
  languages          String[] @default([])
  photoUrl           String?
  availableDays      String[] @default([])  // ["Mon","Tue","Wed",...]
  availableForOnline Boolean  @default(true)
  consultationFee    Int?     // INR
  contact            String?
  address            String?
  // ─── Social links (added 2026-05-12). Optional URLs; validated as http(s)
  // at the API layer. WhatsApp handle derives from `contact` (E.164 → wa.me).
  websiteUrl         String?
  linkedinUrl        String?
  facebookUrl        String?
  instagramUrl       String?
  twitterUrl         String?
  youtubeUrl         String?
  // ─── Provenance / verification (added 2026-05-10 with import pipeline) ──
  tcmcNumber         String?  @unique // Travancore-Cochin Medical Council registration #
  source             String?  // e.g. 'tcmc', 'kerala-tourism', 'self-register', 'admin', 'csv'
  sourceUrl          String?  // URL of the public listing this record came from
  importedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  reviews      Review[]
  appointments Appointment[]
  ownedBy      User?         @relation("OwnedDoctor")
  savedBy      SavedDoctor[]
  slots        DoctorSlot[]
}

// Concrete bookable time slots. Doctors create them; patients pick one when
// they book. Status flips to 'booked' when an Appointment is created against
// it, 'cancelled' if the doctor pulls it.
model DoctorSlot {
  id        String   @id @default(cuid())
  doctorId  String
  startsAt  DateTime
  endsAt    DateTime
  status    String   @default("open") // open | booked | cancelled
  // optional cap on consult-type for this slot ('video' | 'in-person' | 'either')
  type      String   @default("either")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, startsAt])
  @@index([status, startsAt])
}

model Hospital {
  id              String   @id @default(cuid())
  name            String
  type            String
  // Geography (added 2026-05-11). See Doctor model for migration semantics.
  country         String   @default("IN")
  state           String?
  district        String   // legacy: city/region within state
  ccimVerified    Boolean  @default(false)
  ayushCertified  Boolean  @default(false)
  panchakarma     Boolean  @default(false)
  nabh            Boolean  @default(false)
  profile         String?
  establishedYear Int?
  services        String[] @default([])
  contact         String?
  address         String?
  latitude        Float?
  longitude       Float?
  // ─── Social links (added 2026-05-12). See Doctor model for semantics.
  websiteUrl      String?
  linkedinUrl     String?
  facebookUrl     String?
  instagramUrl    String?
  twitterUrl      String?
  youtubeUrl      String?
  // ─── Provenance / classification (added 2026-05-10 with import pipeline) ──
  classification  String?  // 'olive-leaf' | 'green-leaf' | null (Kerala Tourism's official rating)
  source          String?  // e.g. 'kerala-tourism', 'ism-kerala', 'self-register', 'admin', 'csv'
  sourceUrl       String?
  importedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reviews      Review[]
  appointments Appointment[]
  ownedBy      User?         @relation("OwnedHospital")
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?
  userId     String
  doctorId   String?
  hospitalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor   Doctor?   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  hospital Hospital? @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([doctorId])
  @@index([hospitalId])
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  userId    String
  category  String   // doctor-discussion | patient-forum | webinar | research
  language  String   @default("en") // en | ml
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]
  upvotes  Upvote[]

  @@index([userId])
  @@index([category])
}

model Upvote {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model SavedDoctor {
  id        String   @id @default(cuid())
  userId    String
  doctorId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([userId, doctorId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  postId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model Job {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   // doctor | therapist | pharmacist | government
  district    String?
  salary      String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

// ─── WhatsApp job alert subscriptions (added 2026-05-11) ─────────────────
// Public-facing opt-in form (phone + filters); fires on new ImportedJob
// matching the subscriber's preferences. Sends via the existing Twilio
// WhatsApp wrapper (lib/whatsapp.ts). Reply STOP unsubscribes via webhook
// (not yet implemented; admins can flip isActive=false).
model WhatsAppAlertSubscription {
  id              String   @id @default(cuid())
  phone           String   // E.164: +91XXXXXXXXXX
  // Optional filters — all null means "all Kerala Ayurveda jobs"
  specialization  String?
  district        String?
  source          String?  // restrict to one source if user prefers
  isActive        Boolean  @default(true)
  lastSentAt      DateTime?
  consentAt       DateTime @default(now())
  unsubscribedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([phone])
  @@index([isActive, lastSentAt])
}

// ─── Auto-imported Ayurveda jobs (added 2026-05-10 — separate table from Job
// because user-posted jobs require a userId FK; importer rows have no owner) ──
model ImportedJob {
  id              String    @id @default(cuid())
  title           String
  organization    String?
  location        String?           // free-text from source (e.g. "Trivandrum, Kerala")
  description     String?
  qualifications  String?
  lastDate        DateTime?
  applyUrl        String
  source          String            // 'kerala-psc' | 'nhm-kerala' | 'indeed' | 'naukri'
  sourceId        String   @unique  // md5(source + applyUrl + title) — dedupe key
  salary          String?
  jobType         String?           // full-time | part-time | contract | govt
  category        String?           // 'doctor' | 'therapist' | etc.
  isAutoImported  Boolean  @default(true)
  isActive        Boolean  @default(true)
  importedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([source, importedAt])
  @@index([isActive, importedAt])
  @@index([category])
}

model Herb {
  id          String   @id @default(cuid())
  name        String
  sanskrit    String?
  english     String?
  malayalam   String?
  rasa        String?
  guna        String?
  virya       String?
  vipaka      String?
  description String?
  uses        String?
  // pgvector embedding (Gemini text-embedding-004 → 768 dims). Added via raw
  // SQL in 20260510180000_pgvector_search migration since Prisma can't yet
  // type-check the `vector` column. Indexed with HNSW for fast cosine search.
  // Generated by POST /admin/embed/herbs after seed.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MedicalCollege {
  id        String   @id @default(cuid())
  name      String
  district  String
  type      String   // ayurveda | modern
  profile   String?
  contact   String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id              String    @id @default(cuid())
  userId          String
  doctorId        String?
  hospitalId      String?
  dateTime        DateTime
  type            String    // consultation-video | consultation-in-person | panchakarma
  status          String    @default("scheduled") // scheduled | confirmed | reschedule-proposed | completed | cancelled | no-show | declined
  notes           String?
  chiefComplaint  String?
  duration        String?   // "less than a week" | "1-4 weeks" | "1-6 months" | "more than 6 months"
  fee             Int?      // INR
  paymentStatus   String?   // pending | paid | refunded | failed | free
  paymentProvider String?   // razorpay | manual
  paymentRef      String?   // razorpay order_id / payment_id
  // Doctor's decision audit + reschedule proposals (set by /accept, /decline, /propose-new-time):
  declineReason   String?   // when status=declined
  proposedAt      DateTime? // alternate dateTime proposed by doctor when status=reschedule-proposed
  // Reminder de-dupe — prevents the cron from firing the same reminder twice:
  reminded24hAt   DateTime?
  reminded1hAt    DateTime?
  reviewPrompted  Boolean   @default(false) // post-appointment "leave a review" notification fired
  // Online consultation clinical record (filled by doctor during/after the call):
  consultationStartedAt DateTime?
  consultationEndedAt   DateTime?
  consultationSummary   String?   // observations / diagnosis — visible to patient
  prescription          String?   // medications, dosages, duration — visible to patient
  treatmentPlan         String?   // recommended Panchakarma, lifestyle, follow-up — visible to patient
  doctorPrivateNotes    String?   // doctor's private clinical notes — never shown to patient
  followUpRecommended   Boolean   @default(false)
  followUpAfterWeeks    Int?      // doctor's suggested follow-up window
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor   Doctor?   @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  hospital Hospital? @relation(fields: [hospitalId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([doctorId])
  @@index([status])
  @@index([dateTime])
}

model KnowledgeArticle {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   // classical-text | research | seasonal-health
  source    String?  // Charaka Samhita | Ashtanga Hridayam | PubMed | ...
  language  String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MedicalTourismPackage {
  id          String   @id @default(cuid())
  title       String
  description String
  duration    Int
  price       Float?
  location    String
  includes    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Analytics event log ─────────────────────────────────────────────────
// Lightweight in-DB events for site-wide analytics. Anonymous users are
// keyed by sessionId (cookie); signed-in users link to userId.
model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  name      String   // 'search' | 'doctor_view' | 'ayurbot_chat' | 'booking_started' | ...
  props     Json?
  path      String?  // optional referer path
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([userId, createdAt])
}

// ─── Site-wide admin-editable settings (key/value store) ─────────────────
// Used for social media URLs, contact info, taglines, etc.
// Reading is public; writing is admin-gated.
model SiteSetting {
  key       String   @id  // e.g. 'social.facebook', 'contact.email', 'brand.tagline'
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

model HealthTip {
  id        String   @id @default(cuid())
  title     String
  content   String
  dosha     String   // vata | pitta | kapha | tridosha
  season    String?  // varsha | grishma | vasantha | sharad
  language  String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dosha])
  @@index([season])
}

// ─── Lead capture (added 2026-05-11) ────────────────────────────────────
// Generic inquiries from public lead-capture pages: cost estimator,
// contact form, partnership/franchise enquiries. Admin reviews + replies
// out-of-band. We deliberately do NOT auth-gate the POST endpoint so
// non-registered visitors can submit; rate-limited at the route layer.
//
// Pipeline columns added 2026-05-11b for CRM upgrade — stage drives the
// kanban view in /admin/leads. status retained for back-compat but stage
// is now the source of truth for sales pipeline state.
model Lead {
  id           String   @id @default(cuid())
  kind         String   // 'cost_estimator' | 'contact' | 'partnership' | 'franchise' | 'marketplace_vendor' | 'academy' | 'product_waitlist'
  name         String
  email        String
  phone        String?
  country      String?  // ISO-2
  subject      String?  // short label / treatment slug / partnership type
  message      String
  meta         Json?    // form-specific fields (estimator inputs etc.)
  status       String   @default("new")     // legacy: 'new' | 'contacted' | 'closed' | 'spam'
  stage        String   @default("new")     // CRM: 'new' | 'contacted' | 'qualified' | 'quoted' | 'won' | 'lost' | 'spam'
  assignedToId String?  // admin user assigned to this lead
  followUpAt   DateTime?
  notesJson    Json?    // array of { at, by, text, kind } — timeline
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTo   User?    @relation("LeadAssignee", fields: [assignedToId], references: [id])

  @@index([kind, status, createdAt])
  @@index([stage, createdAt])
  @@index([assignedToId])
  @@index([followUpAt])
  @@index([createdAt])
}

// ─── Prakriti quiz results (added 2026-05-11b) ──────────────────────────
// One row per quiz attempt. Signed-in users link to userId; anonymous
// attempts are stored against sessionId. Used for personalisation later
// (Diet Engine consumes the latest dominant dosha per user).
model PrakritiAssessment {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String?
  vata       Int      // raw score 0-N
  pitta      Int
  kapha      Int
  dominant   String   // 'vata' | 'pitta' | 'kapha' | 'vata-pitta' | 'pitta-kapha' | 'vata-kapha' | 'tridoshic'
  responses  Json     // map of questionId -> 'V' | 'P' | 'K'
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([dominant])
  @@index([createdAt])
}

// ─── AI Diet Engine outputs (added 2026-05-11b) ─────────────────────────
// Cached LLM-generated meal plans. Re-use if dosha + season + conditions +
// preferences match a recent plan (within 30 days) to avoid burning quota
// for identical requests.
model DietPlan {
  id           String   @id @default(cuid())
  userId       String?
  dosha        String
  season       String?
  conditions   String[]
  preferences  Json?    // { vegetarian, eggs, dairy, allergies, region }
  output       Json     // { days: [{ meals: [...] }], favorFoods, avoidFoods, principles }
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([dosha, season])
  @@index([createdAt])
}

// ---------- AyurBot RAG (Phase 4) ----------
// Vector column added via raw SQL in migration after CREATE EXTENSION vector.
model KnowledgeChunk {
  id        String   @id @default(cuid())
  source    String
  chapter   String?
  text      String
  language  String   @default("en")
  createdAt DateTime @default(now())

  @@index([source])
}
